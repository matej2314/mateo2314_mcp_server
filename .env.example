# Moduły (false wyłącza)
# ENABLE_MODULE_PORTFOLIO=false
# ENABLE_MODULE_TEST_TOOLS=false

PORTFOLIO_NAMESPACE=portfolio
# Ścieżka do katalogu content (domyślnie względem skompilowanego lib — po buildzie ustaw na dist/.../content)
# PORTFOLIO_CONTENT_ROOT=./src/modules/portfolio/content
PORTFOLIO_CORPUS_VERSION=1.0.0

TEST_TOOLS_NAMESPACE=test

# Streamable HTTP (domyślny transport w src/index.ts)
MCP_HOST=127.0.0.1
MCP_PORT=3333
# Opcjonalnie: niepusty token — wtedy każde żądanie musi mieć Authorization: Bearer <token>
 MCP_INTERNAL_TOKEN=your_token_here