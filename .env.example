# === Moduł Portfolio (MVP) ===
ENABLE_MODULE_PORTFOLIO=true
PORTFOLIO_NAMESPACE=portfolio
PORTFOLIO_CONTENT_ROOT=./src/modules/portfolio/content
PORTFOLIO_CORPUS_VERSION=0.1.0

# === Produkcja: Baza danych (opcjonalnie) ===
# PORTFOLIO_DB_URL=postgresql://mcp_readonly:password@localhost:5432/portfolio?schema=public

# === Transport (MVP: stdio, Produkcja: http) ===
# MCP_TRANSPORT=stdio
# MCP_PORT=3333
# MCP_INTERNAL_TOKEN=your-secret-token

# === Przyszłe moduły (wyłączone w MVP) ===
# ENABLE_MODULE_ECOMMERCE=false
# ECOMMERCE_NAMESPACE=shop
# ECOMMERCE_DB_URL=postgresql://...

# ENABLE_MODULE_ANALYTICS=false
# ANALYTICS_NAMESPACE=analytics
# ANALYTICS_API_URL=http://analytics-api:8080
# ANALYTICS_API_KEY=your-api-key
